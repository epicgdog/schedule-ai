# Database - absolute or relative path to SQLite database
DATABASE=db/main.db

# Turso (optional) - leave empty to use local SQLite
# TURSO_DATABASE_URL=
# TURSO_ACCESS_TOKEN=

# LLM Configuration
# Ollama base URL with v1 format (e.g., http://localhost:11434/v1)
LOCAL_IP_KEY=http://localhost:11434/v1

# Groq API (optional) - for program requirements scraping
# GROQ_API_KEY=

# Firecrawl (optional) - for web scraping
# FIRE_CRAWL_KEY=
